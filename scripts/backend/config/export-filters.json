{
  "contentFilter": {
    "enabled": true,
    "patterns": [
      "harem",
      "haremlit",
      "reverse\\s*harem",
      "men'?s\\s*adventure",
      "smut",
      "erotic",
      "\\bspicy\\b",
      "adult\\s*fantasy\\s*romance",
      "intimate\\s*scene",
      "monster\\s*romance",
      "romantasy",
      "omegaverse",
      "fated\\s*mate",
      "rejected\\s*mate",
      "alpha.*omega",
      "heat\\s*cycle",
      "breeding",
